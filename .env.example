MTGO_SQL_SERVER=YOUR_SQL_SERVER
MTGO_SQL_DATABASE=YOUR_DATABASE_NAME

# Optional when not using Windows authentication:
MTGO_SQL_USER=YOUR_SQL_USER
MTGO_SQL_PASSWORD=YOUR_SQL_PASSWORD

# Optional local HTTPS certificate for Vite dev/preview server:
MTGO_HTTPS_ENABLED=false
MTGO_HTTPS_PFX_PATH=./certs/mt-go-web-dev.pfx
MTGO_HTTPS_PFX_PASSWORD=mt-go-web-local

# Optional host/port for LAN access:
MTGO_DEV_HOST=0.0.0.0
MTGO_DEV_PORT=5174
MTGO_PREVIEW_HOST=0.0.0.0
MTGO_PREVIEW_PORT=4174
